pipeline {
    agent any

    stages {
        stage('Hello') {
            steps {
                echo 'Hello DevOps Engineer!'
            }
        }

        stage('Linux Commands') {
            steps {
                sh 'pwd'
                sh 'whoami'
                sh 'hostname'
                sh 'date'
                sh 'ls -la'
            }
        }
    }
}
